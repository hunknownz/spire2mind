# Spire2Mind per-machine config. Copy to .env.local and edit as needed.
# .env.local is gitignored; .env.local.example is the committed template.
#
# Values here are sourced by scripts/start-all.sh before launching the
# agent/TUI, Kokoro TTS server, and tts-player. All variables are optional —
# anything unset falls back to the defaults baked into start-all.sh.

# --- Bridge (Windows host running SlayTheSpire2 + Spire2Mind.Bridge.dll) ---
# Prefer a hostname so Windows IP changes don't break you.
# `jack.local` resolves via mDNS/Bonjour (macOS built-in) on the same LAN.
SPIRE2MIND_BRIDGE_HOST=jack.local
SPIRE2MIND_BRIDGE_PORT=8080

# Alternatively, override the full URL and the host/port above are ignored:
# SPIRE2MIND_BRIDGE_URL=http://192.168.3.31:8080

# --- Model provider (Mac agent/TUI uses the LAN OpenAI-compatible Qwen endpoint) ---
SPIRE2MIND_MODEL_PROVIDER=api
SPIRE2MIND_API_PROVIDER=openai
SPIRE2MIND_API_BASE_URL=http://192.168.3.23:11434
# Trusted local/LAN API can leave the key blank.
SPIRE2MIND_API_KEY=
SPIRE2MIND_API_DECISION_MODE=structured
SPIRE2MIND_MODEL=qwen3.5:35b-a3b-coding-nvfp4
SPIRE2MIND_MODEL_CONTEXT=32768

# --- Kokoro TTS server (runs locally on the Mac) ---
KOKORO_PORT=18081
KOKORO_VOICE=zf_xiaoxiao
KOKORO_LANG=z

# --- tts-player (Node sidecar that consumes agent beats) ---
SPIRE2MIND_TTS_PROVIDER=kokoro
SPIRE2MIND_TTS_FALLBACK_PROVIDER=kokoro
# SPIRE2MIND_TTS_BASE_URL defaults to http://127.0.0.1:${KOKORO_PORT}
SPIRE2MIND_TTS_MODEL=kokoro
# SPIRE2MIND_TTS_VOICE defaults to ${KOKORO_VOICE}
SPIRE2MIND_TTS_FORMAT=wav

# --- Optional: API keys for cloud providers (leave blank if unused) ---
# SPIRE2MIND_TTS_API_KEY=
